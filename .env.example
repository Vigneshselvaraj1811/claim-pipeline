# -------------------------------------------------------
# Claim Processing Pipeline - Environment Configuration
# Copy this file to .env and fill in your values
# -------------------------------------------------------

LLM_PROVIDER=groq

GROQ_API_KEY=your_groq_api_key_here
LLM_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=4096

PDF_MAX_PAGES=100
PDF_IMAGE_DPI=150
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=20